class PrototypeDemo {
    public static void main(String[] args) {
        ICURoomPrototype baseRoom = new ICURoomPrototype();
        try {
            ICURoomPrototype room1 = baseRoom.clone();
            ICURoomPrototype room2 = baseRoom.clone();

            room1.showConfig();
            room2.showConfig();
        } catch (CloneNotSupportedException e) {
            e.printStackTrace();
        }
    }
}
